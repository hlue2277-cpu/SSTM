<UserControl x:Class="SSTMTerminal.Controls.PlusMinusCountIItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SSTMTerminal.Controls"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Width="170"
             Height="40"
             d:DesignHeight="300"
             d:DesignWidth="300"
             Background="Transparent"
             mc:Ignorable="d">
    <Grid Background="#f5f5f5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <local:IconButton x:Name="minus"
                          Width="38"
                          Height="38"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Click="minus_Click"
                          IsEnabled="{Binding IsMinusEnable, RelativeSource={RelativeSource AncestorLevel=1, AncestorType={x:Type local:PlusMinusCountIItem}, Mode=FindAncestor}}"
                          MouseLeftButtonDown="minus_MouseLeftButtonDown">
            <local:IconButton.Background>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/minus.png" />
            </local:IconButton.Background>
            <local:IconButton.DisableBrush>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/minusDisable.png" />
            </local:IconButton.DisableBrush>
        </local:IconButton>

        <TextBlock Grid.Column="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="18"
                   Foreground="Black"
                   Text="{Binding Count, RelativeSource={RelativeSource AncestorLevel=1, AncestorType={x:Type local:PlusMinusCountIItem}, Mode=FindAncestor}}" />

        <local:IconButton x:Name="plus"
                          Grid.Column="2"
                          Width="38"
                          Height="38"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Click="plus_Click"
                          IsEnabled="{Binding IsPlusEnable, RelativeSource={RelativeSource AncestorLevel=1, AncestorType={x:Type local:PlusMinusCountIItem}, Mode=FindAncestor}}"
                          MouseLeftButtonDown="plus_MouseLeftButtonDown">
            <local:IconButton.Background>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/plus.png" />
            </local:IconButton.Background>
            <local:IconButton.DisableBrush>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/plusDisable.png" />
            </local:IconButton.DisableBrush>
        </local:IconButton>
    </Grid>
</UserControl>

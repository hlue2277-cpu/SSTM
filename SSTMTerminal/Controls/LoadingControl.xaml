            <ei:DataTrigger Binding="{Binding IsBusy,
                                        ElementName=m_self}"
                      Value="true">
                <ei:ChangePropertyAction PropertyName="Visibility"
                                 Value="Visible" />
            </ei:DataTrigger>

            <ei:DataTrigger Binding="{Binding IsBusy,
                                        ElementName=m_self}"
                      Value="false">
                <ei:ChangePropertyAction PropertyName="Visibility"
                                 Value="Collapsed" />
            </ei:DataTrigger>
        </i:Interaction.Triggers>


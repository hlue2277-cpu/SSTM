<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:SSTMTerminal.Behaviors"
                    xmlns:local="clr-namespace:SSTMTerminal.Styles">
    <Style x:Key="PasswordBoxStyle" TargetType="{x:Type PasswordBox}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="CaretBrush" Value="#6371a1" />
        <Setter Property="Foreground" Value="#6371a1" />
        <Setter Property="PasswordChar" Value="*" />
        <Setter Property="Width" Value="238" />
        <Setter Property="Height" Value="42" />
        <Setter Property="AllowDrop" Value="true" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type PasswordBox}">
                    <Grid Background="Transparent">
                        <TextBlock x:Name="tipTextBlock"
                                   Margin="35,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#6371a1"
                                   Text="请输入密码"
                                   Visibility="Collapsed" />
                        <Border x:Name="Border"
                                Margin="2"
                                Padding="2"
                                BorderBrush="#6371a1"
                                BorderThickness="3"
                                CornerRadius="2">
                            <StackPanel Orientation="Horizontal">
                                <Image MaxHeight="20"
                                       Margin="5,0,0,0"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Source="../Images/secret.png"
                                       Stretch="Uniform" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="5,0,0,0"
                                              VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border x:Name="outerBorder"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                BorderBrush="#6371a1"
                                BorderThickness="2"
                                CornerRadius="3"
                                Opacity="0.3"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="behaviors:PasswordBoxBehavior.Password" Value="{x:Null}">
                            <Setter TargetName="tipTextBlock" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="behaviors:PasswordBoxBehavior.Password" Value="">
                            <Setter TargetName="tipTextBlock" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="tipTextBlock" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="outerBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
<UserControl x:Class="SSTMTerminal.Views.ExhibitionTicketTimeSlotsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Margin="60,40,60,40">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,40">
            

            <TextBlock Text="请选择参观时段" 
                       FontSize="42" FontWeight="Bold" Foreground="#1A3C34"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- 时段列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      Background="Transparent" Padding="0,0,0,30">
            <ItemsControl ItemsSource="{Binding TimeSlots}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.SelectExhibitionTicketTimeSlotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}"
                IsEnabled="{Binding IsAvailable}"
                Margin="0,0,0,25"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand">
                            <Border Background="White"
                    BorderBrush="#E5E5E5"
                    BorderThickness="2" 
                    CornerRadius="18"
                    Padding="35,32">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：展厅 + 时间范围 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Width="310">
                                        <TextBlock Text="{Binding DisplayName}" 
                                   FontSize="30" FontWeight="Medium" Foreground="#1A3C34"
                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- 中间：开演时间 -->
                                    <StackPanel Grid.Column="1" Margin="50,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="开演时间" FontSize="17" Foreground="#666" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding ShowTime, StringFormat='{}{0}点'}" 
                                   FontSize="27" FontWeight="Medium" Foreground="#1A3C34"/>
                                    </StackPanel>

                                    <!-- 右侧：剩余票数 -->
                                    <!-- 右侧：剩余票数 -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Width="160">
                                        <TextBlock Text="{Binding RemainingTickets, StringFormat='剩余: {0}'}" 
               FontSize="21" Foreground="#1A3C34" TextAlignment="Right" FontWeight="Medium"/>

                                        <TextBlock Text="无法预约" 
               Visibility="{Binding NotAvailable, Converter={StaticResource booleanToVisibilityConverter}}"
               FontSize="16" Foreground="#D2001E" TextAlignment="Right" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <!-- 底部按钮 -->
        <Grid Grid.Row="2" Margin="0,40,0,0">
            <Button Command="{Binding BackToHomeCommand}"
                    Width="380" Height="92"
                    Background="#1A3C34"
                    Foreground="White"
                    FontSize="28"
                    FontWeight="Medium"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Center">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="← 返回" Margin="0,0,12,0"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </Grid>
    </Grid>
</UserControl>
<controls:NotifyUC x:Class="SSTMTerminal.Views.SelectTicketsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behavior="clr-namespace:SSTMTerminal.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:controls="clr-namespace:SSTMTerminal.Controls"
             xmlns:local="clr-namespace:SSTMTerminal.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 x:Name="m_self"
             IsTimerEnable="{Binding IsTimerEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             TimeOutCommand="{Binding BackToHomeCommand}"
			 CountDown="{Binding CountDown, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             mc:Ignorable="d">
	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<Style x:Key="ListBoxItemTransparentSelectedStyle" TargetType="ListBoxItem">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ListBoxItem">
						<Border Name="ItemBorder"
                                SnapsToDevicePixels="true">
							<ContentPresenter />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsSelected" Value="true">
								<Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="100" />
			<RowDefinition Height="100" />
			<RowDefinition Height="954" />
			<RowDefinition Height="35" />
			<RowDefinition Height="102" />
			<RowDefinition Height="55" />
			<RowDefinition Height="114" />
		</Grid.RowDefinitions>

		<Border Grid.Row="0">
			<Border.Background>
				<ImageBrush ImageSource="/SSTMTerminal;component/Images/SelectTicketPageTitle.png" Stretch="None"/>
			</Border.Background>
		</Border>

		<ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
					  Background="Transparent" BorderBrush="Transparent">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="845"/>
					<ColumnDefinition Width="10" />
				</Grid.ColumnDefinitions>
				<ListBox x:Name="TicketListBox" Grid.Column="0"
						 ItemsSource="{Binding Tickets}"
						 BorderBrush="Transparent"
						 BorderThickness="0"
						 SelectionMode="Single"
						 Background="Transparent"
						 HorizontalAlignment="Left"
						 ItemContainerStyle="{DynamicResource ListBoxItemTransparentSelectedStyle}">
					<ListBox.ItemTemplate>
						<DataTemplate >
							<Border Width="842" Height="172" Margin="0,0,0,20">
								<Border.Background>
									<ImageBrush ImageSource="{Binding TicketItemBackgroundImageSource, UpdateSourceTrigger=PropertyChanged}" Stretch="None"/>
								</Border.Background>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>
									<StackPanel Orientation="Vertical" Grid.Column="0" Margin="30,10,20,10" VerticalAlignment="Center">
										<TextBlock Text="{Binding TicketName}" HorizontalAlignment="Left" VerticalAlignment="Top"
										   FontSize="40" FontFamily="微软雅黑" Margin="0,0,0,10" FontWeight="Bold" />
										<TextBlock Text="{Binding TicketDetail}"  HorizontalAlignment="Left" VerticalAlignment="Bottom"
										   FontFamily="微软雅黑" FontSize="34" />
									</StackPanel>
									<Button Grid.Column="1" Width="52" Height="52" HorizontalAlignment="Right"
											VerticalAlignment="Center" Margin="20" Visibility="{Binding CanSelect, Converter={StaticResource BooleanToVisibilityConverter}}"
											Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}" OverridesDefaultStyle="True"
											CommandParameter="{Binding Path=DataContext, RelativeSource={RelativeSource Self}}">
										<Button.Content>
											<Image Source="{Binding IsCheckedImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
										</Button.Content>
									</Button>

									<TextBlock Grid.Column="1" Height="52" HorizontalAlignment="Right"
											VerticalAlignment="Center" Margin="30,10,20,10"
											Visibility="{Binding ShowStatusText, Converter={StaticResource BooleanToVisibilityConverter}}"
											Text="{Binding StatusText}"
											Background="Transparent" 
											Foreground="#4D4D4D"
											FontSize="40" FontFamily="微软雅黑"
											FontWeight="Bold" />
								</Grid>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Grid>
		</ScrollViewer>

		<Border Grid.Row="4">
			<Border.Background>
				<ImageBrush ImageSource="/SSTMTerminal;component/Images/SelectAll.png" Stretch="None"/>
			</Border.Background>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="全选"
						   HorizontalAlignment="Left" VerticalAlignment="Center"
						   FontSize="34" FontFamily="微软雅黑" Foreground="#D9DADE"
						   Margin="40,0,0,0" />
				<Button Grid.Column="1" Width="52" Height="52" Margin="20"
						HorizontalAlignment="Right" VerticalAlignment="Center"
						Command="{Binding SelectAllCommand}" OverridesDefaultStyle="True">
					<Button.Content>
						<Image Source="{Binding IsAllCheckedImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
					</Button.Content>
				</Button>
			</Grid>
		</Border>

		<Grid Grid.Row="6">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="290" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="521" />
			</Grid.ColumnDefinitions>
			<Button Grid.Column="0" Command="{Binding BackToHomeCommand}" OverridesDefaultStyle="True" HorizontalAlignment="Left">
				<Button.Content>
					<Grid>
						<Image Source="/SSTMTerminal;component/Images/BackSmall2.png" />
						<TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
						   FontFamily="微软雅黑" FontSize="32" Margin="15,10,30,10" Foreground="#D9DADE">
							<Run Text="{Binding CountDown, ElementName=m_self, Mode=OneWay}" />
							<Run Text="秒" />
						</TextBlock>
					</Grid>
				</Button.Content>
			</Button>
			<Button Grid.Column="2" Command="{Binding ConfirmGetTicketCommand}" OverridesDefaultStyle="True" IsEnabled="{Binding IsEnableConfirm}">
				<Button.Content>
					<Image Source="{Binding ConfirmGetTicketImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				</Button.Content>
			</Button>
		</Grid>

	</Grid>
</controls:NotifyUC>

                        </Button.Content>
                    </Button>
                    <Button Grid.Column="1" Grid.Row="7" x:Name="buttonDeleteAlpha" OverridesDefaultStyle="True" Command="{Binding SwitchKeyboardCommand}">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/abc.png" />
                        </Button.Content>
                    </Button>
                    <Button Grid.Column="3" Grid.Row="7" x:Name="button0" OverridesDefaultStyle="True" Click="InputNumberOrAlpha_Click" Tag="0">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/0.png" />
                        </Button.Content>
                    </Button>
                    <Button Grid.Column="5" Grid.Row="7" x:Name="btnDeleteNumber" OverridesDefaultStyle="True"
					Click="RemoveNumberOrAlpha_Click">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/DeleteNumber.png" />
                        </Button.Content>
                    </Button>
                </Grid>


                    </Button>
                    <Button Grid.Column="9" Grid.Row="5" x:Name="buttonO" OverridesDefaultStyle="True" Click="InputNumberOrAlpha_Click" Tag="O">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/o.png" />
                        </Button.Content>
                    </Button>
                    <!--P~T-->
                    <Button Grid.Column="1" Grid.Row="7" x:Name="buttonP" OverridesDefaultStyle="True" Click="InputNumberOrAlpha_Click" Tag="P">

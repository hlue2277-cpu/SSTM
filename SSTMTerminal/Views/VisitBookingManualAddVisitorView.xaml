        <Grid Grid.Row="7" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="521" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{Binding BackToOwnerCommand}" OverridesDefaultStyle="True" HorizontalAlignment="Left">
                <Button.Content>
                    <Image Source="/SSTMTerminal;component/Images/BackSmall.png" />
                </Button.Content>
            </Button>
            <Button Grid.Column="2" Command="{Binding ConfirmAddVisitorCommand}" IsEnabled="{Binding IsConfirmAddVisitorEnabled}" OverridesDefaultStyle="True" HorizontalAlignment="Right">
                <Button.Content>
                    <Image Source="{Binding ConfirmAddVisitorImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Button.Content>
            </Button>
        </Grid>

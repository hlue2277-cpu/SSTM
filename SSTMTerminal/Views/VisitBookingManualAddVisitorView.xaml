                        </Button.Content>
                    </Button>
                    <Button Grid.Column="3" Grid.Row="3" x:Name="button5" OverridesDefaultStyle="True" Click="InputNumberOrAlpha_Click" Tag="5">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/5.png" />
                        </Button.Content>
                    </Button>
                    <Button Grid.Column="5" Grid.Row="3" x:Name="button6" OverridesDefaultStyle="True" Click="InputNumberOrAlpha_Click" Tag="6">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/6.png" />
                        </Button.Content>
                    </Button>

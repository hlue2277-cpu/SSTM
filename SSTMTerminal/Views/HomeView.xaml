<UserControl x:Class="SSTMTerminal.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1600" d:DesignWidth="1080">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 -->
        <Border Grid.Row="0" Height="160" Background="Transparent">
            <TextBlock Text="门票选择" 
                       FontSize="48" FontWeight="Bold" Foreground="#1A3C34"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- 主要内容（大幅往下移动） -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,120,0,0">

            <!-- 特展1 -->
            <Button Command="{Binding BuyExhibitionTicketCommand}"
                    Width="920" Height="280"
                    Margin="0,0,0,40"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Content>
                    <Border Background="White" 
                            BorderBrush="#E5E5E5" 
                            BorderThickness="3" 
                            CornerRadius="25">
                        <Grid Width="900" Height="260">
                            <Image Source="/SSTMTerminal;component/Images/Exhibition1.png" 
                                   Width="260" Height="240" 
                                   HorizontalAlignment="Left" Margin="20,10,0,10"
                                   Stretch="UniformToFill"/>
                            <StackPanel Margin="310,25,40,25" HorizontalAlignment="Left">
                                <TextBlock Text="飞越马丘比丘:" FontSize="34" FontWeight="Bold" Foreground="#1A3C34"/>
                                <TextBlock Text="云端印加之旅" FontSize="34" FontWeight="Bold" Foreground="#1A3C34" Margin="0,4,0,12"/>
                                <TextBlock Text="Flying over Machu Picchu:" FontSize="19" Foreground="#555"/>
                                <TextBlock Text="An Incan Journey in the Clouds" FontSize="19" Foreground="#555" Margin="0,0,0,18"/>
                                <TextBlock Text="地址: 三楼    Address: Third Floor" FontSize="19" Foreground="#777"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button.Content>
            </Button>

            <!-- 特展2 -->
            <Button Command="{Binding BuyExhibitionTicket2Command}"
                    Width="920" Height="280"
                    Margin="0,0,0,60"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Content>
                    <Border Background="White" 
                            BorderBrush="#E5E5E5" 
                            BorderThickness="3" 
                            CornerRadius="25">
                        <Grid Width="900" Height="260">
                            <Image Source="/SSTMTerminal;component/Images/Exhibition2.png" 
                                   Width="260" Height="240" 
                                   HorizontalAlignment="Left" Margin="20,10,0,10"
                                   Stretch="UniformToFill"/>
                            <StackPanel Margin="310,25,40,25" HorizontalAlignment="Left">
                                <TextBlock Text="玛雅大冒险:" FontSize="34" FontWeight="Bold" Foreground="#1A3C34"/>
                                <TextBlock Text="VR新探索" FontSize="34" FontWeight="Bold" Foreground="#1A3C34" Margin="0,4,0,12"/>
                                <TextBlock Text="Maya Adventure:" FontSize="19" Foreground="#555"/>
                                <TextBlock Text="New VR Exploration" FontSize="19" Foreground="#555" Margin="0,0,0,18"/>
                                <TextBlock Text="地址: 二楼    Address: Second Floor" FontSize="19" Foreground="#777"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button.Content>
            </Button>

            <!-- 返回按钮（放在最下方，仿照图片风格） -->
            <Button Command="{Binding BackToStartPageCommand}"
                    Width="380" Height="90"
                    Background="#1A3C34"
                    Foreground="White"
                    FontSize="26"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,40,0,80">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="← 返回" Margin="0,0,10,0"/>
                    </StackPanel>
                </Button.Content>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
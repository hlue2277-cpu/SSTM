<UserControl x:Class="SSTMTerminal.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behavior="clr-namespace:SSTMTerminal.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SSTMTerminal.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Height="1920">
    <UserControl.Resources>

		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<!--  SimpleStyles: Button  -->

        <Style x:Key="ticketBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="behavior:TouchBehavior.EnableTouchEffect" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="100" />
			<RowDefinition Height="282" />
			<RowDefinition Height="50" />
			<RowDefinition Height="50" /> <!--Title Image-->
			<RowDefinition Height="50" />
			<RowDefinition Height="Auto" />
            <RowDefinition Height="80" />
            <RowDefinition Height="167" />
            <RowDefinition Height="80" />
            <RowDefinition Height="167" />
            <RowDefinition Height="80" />
            <RowDefinition Height="167" />
            <RowDefinition Height="*" />
            <RowDefinition Height="100" />
		</Grid.RowDefinitions>

		<Border Grid.Row="1">
			<Border.Background>
				<SolidColorBrush Color="Transparent" />
			</Border.Background>
		</Border>

		<!--<Border Grid.Row="3">
			<Border.Background>
				<ImageBrush ImageSource="/SSTMTerminal;component/Images/HomeTitle.png" Stretch="None"/>
			</Border.Background>
		</Border>-->

		<Border Grid.Row="5">
			<Image Source="{Binding NoticeImagePath}" Stretch="None" />
		</Border>

        <Button Grid.Row="7" Command="{Binding VisitBookingCommand}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="Collapsed">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/VisitBooking.png" />
            </Button.Content>
        </Button>

        <Button Grid.Row="9" Command="{Binding BuyExhibitionTicketCommand}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="{Binding ShowExhibitionButton, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/BuyExhibitionTicket.png" />
            </Button.Content>
        </Button>

        <Button Grid.Row="11" Command="{Binding NavigateToGetTicketHomeCommand}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="Collapsed">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/GetTicket.png" />
            </Button.Content>
        </Button>

        <Button Grid.Row="11" Command="{Binding BuyExhibitionTicket2Command}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="{Binding ShowExhibition2Button, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/BuyExhibitionTicket2.png" />
                <!-- 你需要准备这张图片 -->
            </Button.Content>
        </Button>

        <Grid Grid.Row="13" VerticalAlignment="Center" HorizontalAlignment="Right">
			<TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
						   FontFamily="微软雅黑" FontSize="30" Foreground="WhiteSmoke" Text="{Binding Version}" />
		</Grid>
	</Grid>
</UserControl>

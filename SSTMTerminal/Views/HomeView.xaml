<UserControl x:Class="SSTMTerminal.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behavior="clr-namespace:SSTMTerminal.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SSTMTerminal.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Height="1920">
    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <!--  SimpleStyles: Button  -->

        <Style x:Key="ticketBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="behavior:TouchBehavior.EnableTouchEffect" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="142" />
            <RowDefinition Height="48" />
            <RowDefinition Height="51" />
            <!--Title Image-->
            <RowDefinition Height="22" />
            <RowDefinition Height="Auto" MinHeight="8" />
            <RowDefinition Height="33" />
            <RowDefinition Height="16" />
            <RowDefinition Height="57" />
            <RowDefinition Height="168" />
            <RowDefinition Height="173" />
            <RowDefinition Height="202" />
            <RowDefinition />
            <RowDefinition Height="100" />
        </Grid.RowDefinitions>

        <!--<Border Grid.Row="3">
			<Border.Background>
				<ImageBrush ImageSource="/SSTMTerminal;component/Images/HomeTitle.png" Stretch="None"/>
			</Border.Background>
		</Border>-->

        <Border Grid.Row="5">
            <Image Source="{Binding NoticeImagePath}" Stretch="None" />
        </Border>

        <Button Grid.Row="7" Command="{Binding VisitBookingCommand}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="Collapsed" Height="0" Margin="256,6,256,10" Width="0">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/VisitBooking.png" />
            </Button.Content>
        </Button>

        <Button Grid.Row="8" Command="{Binding BuyExhibitionTicketCommand}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="{Binding ShowExhibitionButton, Converter={StaticResource BooleanToVisibilityConverter}}" Height="166" Width="512" Margin="0,52,0,7" Grid.RowSpan="2">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/BuyExhibitionTicket.png" />
            </Button.Content>
        </Button>

        <Button Grid.Row="11" Command="{Binding NavigateToGetTicketHomeCommand}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="Collapsed" Height="0" Margin="256,108,256,94" Width="0">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/GetTicket.png" />
            </Button.Content>
        </Button>

        <Button Grid.Row="11" Command="{Binding BuyExhibitionTicket2Command}"
                Style="{StaticResource ticketBtnStyle}"
                Visibility="{Binding ShowExhibition2Button, Converter={StaticResource BooleanToVisibilityConverter}}" Height="166" Width="512" Margin="0,22,0,14">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/BuyExhibitionTicket2.png" />
                <!-- 你需要准备这张图片 -->
            </Button.Content>
        </Button>

        <Grid Grid.Row="13" VerticalAlignment="Center" HorizontalAlignment="Right" Height="40" Margin="0,30" Width="0">
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
						   FontFamily="微软雅黑" FontSize="30" Foreground="WhiteSmoke" Text="{Binding Version}" />
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="SSTMTerminal.Views.GetTicketHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behavior="clr-namespace:SSTMTerminal.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SSTMTerminal.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Height="1920">
    <UserControl.Resources>

		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<!--  SimpleStyles: Button  -->

        <Style x:Key="ticketBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="behavior:TouchBehavior.EnableTouchEffect" Value="True" />
            <Setter Property="Width" Value="262" />
            <Setter Property="Height" Value="277" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="100" />
            <RowDefinition Height="282" />
            <RowDefinition Height="50" />
			<RowDefinition Height="100" />
			<RowDefinition Height="50" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="30" />
            <RowDefinition Height="277" />
            <RowDefinition Height="*" />
            <RowDefinition Height="114" />
			<RowDefinition Height="100" />
		</Grid.RowDefinitions>

		<Border Grid.Row="1">
			<Border.Background>
                <SolidColorBrush Color="Transparent" />
			</Border.Background>
		</Border>

		<Border Grid.Row="3">
			<Border.Background>
				<ImageBrush ImageSource="/SSTMTerminal;component/Images/HomeTitle.png" Stretch="None"/>
			</Border.Background>
		</Border>

		<Border Grid.Row="5" Visibility="Hidden">
			<Image Source="{Binding NoticeImagePath}" Stretch="None" />
		</Border>

		<Grid Grid.Row="7" VerticalAlignment="Top" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
			    <ColumnDefinition Width="30" />
			    <ColumnDefinition Width="Auto" />
			    <ColumnDefinition Width="30" />
			    <ColumnDefinition Width="Auto" />
		    </Grid.ColumnDefinitions>

			<Button Grid.Column="0"
                    IsEnabled="{Binding IsSwipingIDEnabled}"
                    Command="{Binding GetTicketBySwipingIDCommand}"
                    Style="{StaticResource ticketBtnStyle}"
                    Visibility="{Binding ShowGetTicketBySwipIDButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button.Content>
					<Image Source="/SSTMTerminal;component/Images/GetTicketBySwipingID.png" />
                </Button.Content>
            </Button>

            <Button Grid.Column="2"
                    Command="{Binding GetTicketByInputIDCommand}"
                    Style="{StaticResource ticketBtnStyle}"
                    Visibility="{Binding ShowGetTicketByInputIDButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button.Content>
				    <Image Source="/SSTMTerminal;component/Images/GetTicketByInputID.png" />
                </Button.Content>
            </Button>

			<Button Grid.Column="4"
                    Command="{Binding GetTicketByCellAndOrderCommand}"
                    Style="{StaticResource ticketBtnStyle}"
                    Visibility="{Binding ShowGetTicketByCellAndOrderButton, Converter={StaticResource BooleanToVisibilityConverter}}">
				<Button.Content>
					<Image Source="/SSTMTerminal;component/Images/GetTicketByCellAndOrder.png" />
				</Button.Content>
			</Button>
		</Grid>

        <Button Grid.Row="9" Command="{Binding BackToHomeCommand}" OverridesDefaultStyle="True">
            <Button.Content>
                <Image Source="/SSTMTerminal;component/Images/BackBig.png" />
            </Button.Content>
        </Button>
        <!--<Grid Grid.Row="10" VerticalAlignment="Bottom" HorizontalAlignment="Right">
			<TextBlock HorizontalAlignment="Right" VerticalAlignment="Bottom"
						   FontFamily="微软雅黑" FontSize="30" Foreground="WhiteSmoke" Text="{Binding Version}" />
		</Grid>-->
	</Grid>
</UserControl>

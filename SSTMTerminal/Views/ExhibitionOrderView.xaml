<UserControl x:Class="SSTMTerminal.Views.ExhibitionOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Margin="60,40,60,40">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 订单信息 -->
            <RowDefinition Height="Auto"/>
            <!-- 实名认证标题 -->
            <RowDefinition Height="Auto"/>
            <!-- 认证方式按钮 -->
            <RowDefinition Height="Auto"/>
            <!-- 游客列表标题 -->
            <RowDefinition Height="*"/>
            <!-- 游客列表 -->
            <RowDefinition Height="Auto"/>
            <!-- 底部按钮 -->
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Button Command="{Binding BackToHomeCommand}" 
                    Width="80" Height="80"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                <TextBlock Text="←" FontSize="48" Foreground="#1A3C34" FontWeight="Bold"/>
            </Button>

            <TextBlock Text="实名认证" 
                       FontSize="42" FontWeight="Bold" Foreground="#1A3C34"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- 订单信息卡片 -->
        <Border Grid.Row="1" Background="White" CornerRadius="20" BorderBrush="#E5E5E5" BorderThickness="2" Padding="35,25" Margin="0,0,0,30">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding ExhibitionTicketType}" FontSize="28" FontWeight="Medium" Foreground="#1A3C34"/>
                    <TextBlock Text="{Binding ExhibitionTicketPrice}" FontSize="32" FontWeight="Bold" Foreground="#D2001E" Grid.Column="1" HorizontalAlignment="Right"/>
                </Grid>
                <TextBlock Text="{Binding DateTime}" FontSize="19" Foreground="#666" Margin="0,12,0,8"/>
                <TextBlock Text="{Binding VisitorCountString}" FontSize="19" Foreground="#666"/>
            </StackPanel>
        </Border>

        <!-- 实名认证标题 -->
        <TextBlock Grid.Row="2" Text="请选择实名认证方式" 
                   FontSize="28" FontWeight="Medium" Foreground="#1A3C34" Margin="0,0,0,20"/>

        <!-- 认证方式按钮（三列） -->
        <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,40" HorizontalAlignment="Center">

            <!-- 刷身份证 -->
            <Button Command="{Binding SwipAddVisitorCommand}" Margin="10" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Border Background="White" CornerRadius="18" BorderBrush="#E5E5E5" BorderThickness="2" Padding="15">
                    <StackPanel>
                        <Image Source="/SSTMTerminal;component/Images/IDCard.png" Width="160" Height="160" Margin="0,10"/>
                        <TextBlock Text="刷身份证" FontSize="20" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Swipe ID card" FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Button>

            <!-- 手工输入 -->
            <Button Command="{Binding ManualAddVisitorCommand}" Margin="10" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Border Background="White" CornerRadius="18" BorderBrush="#E5E5E5" BorderThickness="2" Padding="15">
                    <StackPanel>
                        <Image Source="/SSTMTerminal;component/Images/ManualInput.png" Width="160" Height="160" Margin="0,10"/>
                        <TextBlock Text="手工输入" FontSize="20" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Manual Input" FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Button>

            <!-- 外国人永居证 -->
            <Button Command="{Binding SwipAddForeignerVisitorCommand}" Margin="10" Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Border Background="White" CornerRadius="18" BorderBrush="#E5E5E5" BorderThickness="2" Padding="15">
                    <StackPanel>
                        <Image Source="/SSTMTerminal;component/Images/ForeignID.png" Width="160" Height="160" Margin="0,10"/>
                        <TextBlock Text="外国人永居证" FontSize="20" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="Permanent Residence" FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Button>
        </UniformGrid>

        <!-- 游客列表标题 -->
        <TextBlock Grid.Row="4" Text="已添加游客" FontSize="28" FontWeight="Medium" Foreground="#1A3C34" Margin="0,0,0,15"/>

        <!-- 游客列表（保留原有功能） -->
        <ListBox Grid.Row="5" x:Name="VisitorListBox"
                 ItemsSource="{Binding Visitors}"
                 BorderBrush="Transparent"
                 Background="Transparent"
                 HorizontalAlignment="Stretch"
                 ItemContainerStyle="{DynamicResource ListBoxItemTransparentSelectedStyle}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Width="920" Height="87" Margin="0,0,0,15" Background="White" CornerRadius="12" BorderBrush="#E5E5E5" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ID}" 
                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                       FontSize="32" Margin="30,0,0,0" Foreground="#1A3C34"/>
                            <Button Grid.Column="1" Width="60" Height="60" Margin="0,0,20,0"
                                    Command="{Binding DataContext.DeleteVisitorCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBox}}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" BorderThickness="0">
                                <Image Source="/SSTMTerminal;component/Images/Clear.png" Width="40"/>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 底部按钮 -->
        <Grid Grid.Row="6" Margin="0,40,0,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 确认按钮（彻底去除白色背景 + 文字居中） -->
            <Button Command="{Binding PayForTicketsCommand}"
                    Width="340" Height="88"
                    Background="Transparent"
                    BorderThickness="0"
                    IsEnabled="{Binding IsPayForTicketsEnabled}"
                    HorizontalAlignment="Center">
                <Border Background="#1A3C34"
                        CornerRadius="15"
                        Padding="0"
                        Width="340" Height="88">
                    <TextBlock Text="确认"
                               FontSize="32"
                               FontWeight="Medium"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Button>
        </Grid>
    </Grid>
</UserControl>
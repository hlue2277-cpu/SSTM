<UserControl x:Class="SSTMTerminal.Views.ExhibitionOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Margin="80,80,80,60">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter"/>
        <Style x:Key="ListBoxItemTransparentSelectedStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Name="ItemBorder"
                        SnapsToDevicePixels="true">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="282" />
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" /><!--A title image-->
            <RowDefinition Height="150" />
            <RowDefinition Height="2" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
            <RowDefinition Height="2" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Border.Background>
                <SolidColorBrush Color="Transparent" />
            </Border.Background>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.38*" />
                <ColumnDefinition Width="0.37*" />
                <ColumnDefinition Width="0.25*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="特展购票" Grid.Column="0" FontSize="70" Foreground="#D2001E" FontFamily="微软雅黑"
                       VerticalAlignment="Bottom" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding DateAndDay}" Grid.Column="1" FontSize="30" Foreground="WhiteSmoke"
                       FontFamily="微软雅黑" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
            <Button Grid.Column="3" Command="{Binding BackToHomeCommand}" OverridesDefaultStyle="True"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right">
                <Button.Content>
                    <Image Source="/SSTMTerminal;component/Images/BackRed209.png" Stretch="Uniform" />
                </Button.Content>
            </Button>
        </Grid>

        <GridSplitter Grid.Row="4" Height="2" BorderBrush="WhiteSmoke" IsHitTestVisible="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" />

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256" />
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="75"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="75"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="75"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="1">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/ExhibitionStep1.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="2" Margin="0,0,0,-18">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/StepConnector.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="3">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/ExhibitionStep2.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="4" Margin="0,0,0,-18">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/StepConnector.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="5">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/ExhibitionStep3Chosen.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="6" Margin="0,0,0,-18">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/StepConnector.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="7">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/ExhibitionStep4.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="2" Width="2" BorderBrush="WhiteSmoke" IsHitTestVisible="False" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" />

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="100" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="50" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="票种:" Grid.Row="0" Grid.Column="0" FontSize="38" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ExhibitionTicketType}" Grid.Row="0" Grid.Column="2" FontSize="35" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center"  />
                    <TextBlock Text="单价:" Grid.Row="2" Grid.Column="0" FontSize="38" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ExhibitionTicketPrice}" Grid.Row="2" Grid.Column="2" FontSize="35" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center"  />
                    <TextBlock Text="时段:" Grid.Row="4" Grid.Column="0" FontSize="38" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DateTime}" Grid.Row="4" Grid.Column="2" FontSize="35" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center" />
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="10" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="参观人数(单次限购5张):" Grid.Column="0" FontSize="38" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding VisitorCount}" Grid.Column="2" FontSize="35" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Grid>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="20" />
                        <RowDefinition Height="80" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="180" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding SwipAddVisitorCommand}" IsEnabled="{Binding CanAddVisitor}" OverridesDefaultStyle="True" HorizontalAlignment="Left">
                            <Button.Content>
                                <Image Source="/SSTMTerminal;component/Images/SwipAddVisitorBtn.png" />
                            </Button.Content>
                        </Button>
                        <Button Grid.Column="2" Command="{Binding ManualAddVisitorCommand}" IsEnabled="{Binding CanAddVisitor}" OverridesDefaultStyle="True" HorizontalAlignment="Center">
                            <Button.Content>
                                <Image Source="/SSTMTerminal;component/Images/ManualAddVisitorBtn.png" />
                            </Button.Content>
                        </Button>
                        <Button Grid.Column="4" Command="{Binding SwipAddForeignerVisitorCommand}" IsEnabled="{Binding CanAddVisitor}" OverridesDefaultStyle="True" HorizontalAlignment="Right">
                            <Button.Content>
                                <Image Source="/SSTMTerminal;component/Images/SwipAddForeignerVisitorBtn.png" />
                            </Button.Content>
                        </Button>
                    </Grid>
                </Grid>
                <Grid Grid.Row="4" Width="550">
                    <ListBox x:Name="VisitorListBox" 
                             ItemsSource="{Binding Visitors}"
                             BorderBrush="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             Background="Transparent"
                             HorizontalAlignment="Left"
                             ItemContainerStyle="{DynamicResource ListBoxItemTransparentSelectedStyle}">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollViewer}">
                                <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate >
                                <Border Width="540" Height="87" Margin="0,0,0,15">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding VisitorImagePath, UpdateSourceTrigger=PropertyChanged}" Stretch="None"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ID}" Grid.Column="0" 
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       FontSize="36" FontFamily="微软雅黑"
                                                       Margin="20,0,10,0" />
                                        <Button Grid.Column="2" Width="50" Height="50"
                                                    VerticalAlignment="Center" Margin="10,0,20,0"
                                                    Command="{Binding DataContext.DeleteVisitorCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBox}}}"
                                                    OverridesDefaultStyle="True"
                                                    CommandParameter="{Binding Path=DataContext, RelativeSource={RelativeSource Self}}">
                                            <Button.Content>
                                                <Image Source="/SSTMTerminal;component/Images/Clear.png" />
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Button Grid.Row="6" Width="300" FontFamily="微软雅黑" FontSize="32" Content="{Binding PayTicketCommandText}" Command="{Binding PayForTicketsCommand}" IsEnabled="{Binding IsPayForTicketsEnabled}" OverridesDefaultStyle="True" HorizontalAlignment="Right">
                    <Button.Background>
                        <ImageBrush ImageSource="{Binding PayForTicketsBgImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Button.Background>
                </Button>

                <!--<Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical" Grid.Column="0" >
                            <Label Content="支付" FontSize="28" FontFamily="微软雅黑" Foreground="WhiteSmoke" />
                            <Label Content="方式" FontSize="28" FontFamily="微软雅黑" Foreground="WhiteSmoke"/>
                        </StackPanel>
                        <Button Grid.Column="1" Width="52" Height="52" Margin="-2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Command="{Binding UseWeChatPayCommand}" OverridesDefaultStyle="True">
                            <Button.Content>
                                <Image Source="{Binding WeChatPayCheckImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Button.Content>
                        </Button>
                        <Border Grid.Column="2">
                            <Border.Background>
                                <ImageBrush ImageSource="/SSTMTerminal;component/Images/WeChatPay.png" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>

                        <Button Grid.Column="4" Width="52" Height="52" Margin="-2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Command="{Binding UseAliPayCommand}" OverridesDefaultStyle="True">
                            <Button.Content>
                                <Image Source="{Binding AliPayCheckImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Button.Content>
                        </Button>
                        <Border Grid.Column="5">
                            <Border.Background>
                                <ImageBrush ImageSource="/SSTMTerminal;component/Images/AliPay.png" Stretch="UniformToFill" />
                            </Border.Background>
                        </Border>
                    </Grid>

                    <Button Grid.Column="2" Width="180" FontFamily="微软雅黑" FontSize="32" Content="{Binding PayTicketCommandText}" Command="{Binding PayForTicketsCommand}" IsEnabled="{Binding IsPayForTicketsEnabled}" OverridesDefaultStyle="True" HorizontalAlignment="Left">
                        <Button.Background>
                            <ImageBrush ImageSource="{Binding PayForTicketsBgImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Button.Background>
                    </Button>
                </Grid>-->
            </Grid>
        </Grid>

        <GridSplitter Grid.Row="8" Height="2" BorderBrush="WhiteSmoke" IsHitTestVisible="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" />

        <!--<Border Grid.Row="8">
            <Border.Background>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/BookingNotice.png" Stretch="Fill" />
            </Border.Background>
        </Border>-->
    </Grid>
</UserControl>

<UserControl x:Class="SSTMTerminal.Views.ExhibitionTicketTypeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Margin="60,40,60,40">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,40">
            

            <TextBlock Text="选择票种" 
                       FontSize="42" FontWeight="Bold" Foreground="#1A3C34"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- 票种列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      Background="Transparent" Padding="0,0,0,40">
            <ItemsControl ItemsSource="{Binding ExhibitionTicketTypes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.SelectExhibitionTicketTypeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding IsAvailable}"
                                Margin="0,0,0,25"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Border Background="White"
                                    BorderBrush="#E5E5E5"
                                    BorderThickness="2"
                                    CornerRadius="20"
                                    Padding="35,32">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 左侧：票种名称 + 说明 -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TicketType}" 
                                                   FontSize="32" FontWeight="Medium" Foreground="#1A3C34"/>
                                        <TextBlock Text="{Binding TicketTypeDescription}" 
                                                   FontSize="18" Foreground="#666" Margin="0,12,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- 右侧：价格 -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Width="140">
                                        <TextBlock Text="{Binding TicketPriceString}" 
                                                   FontSize="36" FontWeight="Bold" Foreground="#D2001E"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部返回按钮 -->
        <Grid Grid.Row="2" Margin="0,40,0,40">
            <Button Command="{Binding BackToHomeCommand}"
                    Width="400" Height="95"
                    Background="#1A3C34"
                    Foreground="White"
                    FontSize="29"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Center">
                ← 返回
            </Button>
        </Grid>
    </Grid>
</UserControl>
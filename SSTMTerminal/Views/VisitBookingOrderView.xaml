<UserControl x:Class="SSTMTerminal.Views.VisitBookingOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Margin="80,80,80,60">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter"/>
        <Style x:Key="ListBoxItemTransparentSelectedStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Name="ItemBorder"
                        SnapsToDevicePixels="true">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="282" />
            <RowDefinition Height="50" />
            <RowDefinition Height="Auto" /><!--A title image-->
            <RowDefinition Height="150" />
            <RowDefinition Height="2" />
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
            <RowDefinition Height="2" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Border.Background>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/logo.png" Stretch="Uniform" />
            </Border.Background>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.38*" />
                <ColumnDefinition Width="0.37*" />
                <ColumnDefinition Width="0.25*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="自助预约" Grid.Column="0" FontSize="70" Foreground="#D2001E" FontFamily="微软雅黑"
                       VerticalAlignment="Bottom" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding DateAndDay}" Grid.Column="1" FontSize="30" Foreground="WhiteSmoke"
                       FontFamily="微软雅黑" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
            <Button Grid.Column="3" Command="{Binding BackToHomeCommand}" OverridesDefaultStyle="True"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right">
                <Button.Content>
                    <Image Source="/SSTMTerminal;component/Images/BackRed209.png" Stretch="Uniform" />
                </Button.Content>
            </Button>
        </Grid>

        <GridSplitter Grid.Row="4" Height="2" BorderBrush="WhiteSmoke" IsHitTestVisible="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" />

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256" />
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/VisitBookingStep1.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="1" Margin="0,0,0,-35">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/StepConnector.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="2">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/VisitBookingStep2Chosen.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="3" Margin="0,0,0,-35">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/StepConnector.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
                <Border Grid.Row="4">
                    <Border.Background>
                        <ImageBrush ImageSource="/SSTMTerminal;component/Images/VisitBookingStep3.png" Stretch="Uniform" />
                    </Border.Background>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="2" Width="2" BorderBrush="WhiteSmoke" IsHitTestVisible="False" VerticalAlignment="Stretch" VerticalContentAlignment="Stretch" />

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="88" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="10" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="预约时段:" Grid.Row="0" Grid.Column="0" FontSize="38" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding TimeSlot}" Grid.Row="0" Grid.Column="2" FontSize="35" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" />
                    <TextBlock Text="参观人数:" Grid.Row="2" Grid.Column="0" FontSize="38" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding VisitorCount}" Grid.Row="2" Grid.Column="2" FontSize="35" Foreground="WhiteSmoke" FontFamily="微软雅黑" HorizontalAlignment="Left" />
                </Grid>

                <Grid Grid.Row="1" Height="80">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Command="{Binding SwipAddVisitorCommand}" IsEnabled="{Binding CanAddVisitor}" OverridesDefaultStyle="True" HorizontalAlignment="Left">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/SwipAddVisitorBtn.png" />
                        </Button.Content>
                    </Button>
                    <Button Grid.Column="2" Command="{Binding ManualAddVisitorCommand}" IsEnabled="{Binding CanAddVisitor}" OverridesDefaultStyle="True" HorizontalAlignment="Center">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/ManualAddVisitorBtn.png" />
                        </Button.Content>
                    </Button>
                    <Button Grid.Column="4" Command="{Binding SwipAddForeignerVisitorCommand}" IsEnabled="{Binding CanAddVisitor}" OverridesDefaultStyle="True" HorizontalAlignment="Right">
                        <Button.Content>
                            <Image Source="/SSTMTerminal;component/Images/SwipAddForeignerVisitorBtn.png" />
                        </Button.Content>
                    </Button>
                </Grid>
                
                <Grid Grid.Row="3" Width="550">
                    <ListBox x:Name="VisitorListBox" 
                             ItemsSource="{Binding Visitors}"
                             BorderBrush="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             Background="Transparent"
                             HorizontalAlignment="Left"
                             ItemContainerStyle="{DynamicResource ListBoxItemTransparentSelectedStyle}">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollViewer}">
                                <Setter Property="HorizontalScrollBarVisibility" Value="Hidden"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate >
                                <Border Width="540" Height="87" Margin="0,0,0,20">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding VisitorImagePath, UpdateSourceTrigger=PropertyChanged}" Stretch="None"/>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ID}" Grid.Column="0" 
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center"
                                                       FontSize="36" FontFamily="微软雅黑"
                                                       Margin="20,0,10,0" />
                                        <Button Grid.Column="2" Width="50" Height="50"
                                                    VerticalAlignment="Center" Margin="10,0,20,0"
                                                    Command="{Binding DataContext.DeleteVisitorCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ListBox}}}"
                                                    OverridesDefaultStyle="True"
                                                    CommandParameter="{Binding Path=DataContext, RelativeSource={RelativeSource Self}}">
                                            <Button.Content>
                                                <Image Source="/SSTMTerminal;component/Images/Clear.png" />
                                            </Button.Content>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1" Command="{Binding ConfirmBookingCommand}" IsEnabled="{Binding IsConfirmBookingEnabled}" OverridesDefaultStyle="True" HorizontalAlignment="Right">
                        <Button.Content>
                            <Image Source="{Binding ConfirmBookingImageSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Button.Content>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
        
        <GridSplitter Grid.Row="8" Height="2" BorderBrush="WhiteSmoke" IsHitTestVisible="False" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" />

        <!--<Border Grid.Row="8">
            <Border.Background>
                <ImageBrush ImageSource="/SSTMTerminal;component/Images/BookingNotice.png" Stretch="Fill" />
            </Border.Background>
        </Border>-->
    </Grid>
</UserControl>
